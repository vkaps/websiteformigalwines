---
import Layout from '../layouts/Layout.astro';

const varietals = [
  'Cabernet Sauvignon',
  'Merlot',
  'Syrah / Shiraz',
  'Touriga Nacional',
  'Touriga Franca',
  'Tinta Roriz (Tempranillo)',
  'Chardonnay',
  'Sauvignon Blanc',
  'Viognier',
  'Alvarinho (Albariño)',
  'Antão Vaz',
  'Rosé (Blend)',
  'Red Blend',
  'White Blend',
  'Other / Custom Specification',
];
---

<Layout
  title="Contact — Trade Inquiry & RFP"
  description="Submit a bulk wine trade inquiry or Request for Proposal to Formigal Wines. Fields for varietal, volume, packaging preference, and company details. B2B only."
>

  <!-- ══════════════════════════════════════
       PAGE HEADER
  ══════════════════════════════════════ -->
  <section class="bg-zinc-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <span class="inline-block text-red-400 text-xs font-bold uppercase tracking-widest mb-3">
          Trade Inquiry · B2B Only
        </span>
        <h1 class="font-serif text-4xl sm:text-5xl font-bold text-white mb-4">
          Request a Quote / RFP
        </h1>
        <p class="text-zinc-400 text-base leading-relaxed">
          Complete the form below and our commercial team will respond within one business day. All inquiries are treated as strictly confidential. We do not sell to the general public.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       MAIN CONTENT: FORM + SIDEBAR
  ══════════════════════════════════════ -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

        <!-- ─── FORM (2/3 width) ─── -->
        <div class="lg:col-span-2">
          <form
            name="b2b-inquiry"
            method="POST"
            action="/contact/success"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-8"
          >
            <!-- Hidden Netlify fields -->
            <input type="hidden" name="form-name" value="b2b-inquiry" />
            <p class="hidden" aria-hidden="true">
              <label>Do not fill: <input name="bot-field" /></label>
            </p>

            <!-- ── Section: Contact Person ── -->
            <fieldset>
              <legend class="font-serif text-xl font-bold text-zinc-900 mb-6 pb-3 border-b border-zinc-200 w-full">
                Contact Person
              </legend>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                <!-- Full Name -->
                <div>
                  <label for="full-name" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Full Name <span class="text-wine-950">*</span>
                  </label>
                  <input
                    type="text"
                    id="full-name"
                    name="full-name"
                    required
                    placeholder="Jane Smith"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Company Name -->
                <div>
                  <label for="company-name" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Company Name <span class="text-wine-950">*</span>
                  </label>
                  <input
                    type="text"
                    id="company-name"
                    name="company-name"
                    required
                    placeholder="Acme Wine Brands Ltd."
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Email -->
                <div>
                  <label for="email" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Business Email <span class="text-wine-950">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="jane@acmewinebrands.com"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Phone -->
                <div>
                  <label for="phone" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Phone / WhatsApp
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="+44 7700 900 123"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Country -->
                <div>
                  <label for="country" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Country / Region <span class="text-wine-950">*</span>
                  </label>
                  <input
                    type="text"
                    id="country"
                    name="country"
                    required
                    placeholder="United Kingdom"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Buyer Type -->
                <div>
                  <label for="buyer-type" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Buyer Type <span class="text-wine-950">*</span>
                  </label>
                  <select
                    id="buyer-type"
                    name="buyer-type"
                    required
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors bg-white"
                  >
                    <option value="" disabled selected>Select buyer type…</option>
                    <option value="private-label-brand">Private Label Brand</option>
                    <option value="wine-merchant">Wine Merchant / Importer</option>
                    <option value="distributor">Distributor / Wholesaler</option>
                    <option value="supermarket-retail">Supermarket / Retail Buyer</option>
                    <option value="hotel-horeca">Hotel / HORECA Operator</option>
                    <option value="co-packer">Co-Packer / Contract Bottler</option>
                    <option value="blender">Blender / Négociant</option>
                    <option value="other">Other — please specify below</option>
                  </select>
                </div>

              </div>
            </fieldset>

            <!-- ── Section: Order Specification ── -->
            <fieldset>
              <legend class="font-serif text-xl font-bold text-zinc-900 mb-6 pb-3 border-b border-zinc-200 w-full">
                Order Specification
              </legend>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                <!-- Requested Varietal -->
                <div>
                  <label for="varietal" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Requested Varietal <span class="text-wine-950">*</span>
                  </label>
                  <select
                    id="varietal"
                    name="varietal"
                    required
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors bg-white"
                  >
                    <option value="" disabled selected>Select varietal…</option>
                    {varietals.map(v => (
                      <option value={v}>{v}</option>
                    ))}
                  </select>
                </div>

                <!-- Vintage Preference -->
                <div>
                  <label for="vintage" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Vintage Preference
                  </label>
                  <input
                    type="text"
                    id="vintage"
                    name="vintage"
                    placeholder="e.g. 2025, or Latest Available"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Target Volume -->
                <div>
                  <label for="volume" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Target Volume (Liters) <span class="text-wine-950">*</span>
                  </label>
                  <input
                    type="text"
                    id="volume"
                    name="volume"
                    required
                    placeholder="e.g. 20,000 L or 2 × Flexitank"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Required Delivery Date -->
                <div>
                  <label for="delivery-date" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Required Delivery Window
                  </label>
                  <input
                    type="text"
                    id="delivery-date"
                    name="delivery-date"
                    placeholder="e.g. Q1 2026 or ASAP"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors"
                  />
                </div>

                <!-- Packaging Preference (full width) -->
                <div class="sm:col-span-2">
                  <label class="block text-sm font-semibold text-zinc-700 mb-2.5">
                    Packaging / Delivery Format <span class="text-wine-950">*</span>
                  </label>
                  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    {[
                      { value: 'flexitank',    label: 'Bulk Flexitank',   sub: '20,000–24,000 L' },
                      { value: 'ibc-totes',    label: 'IBC Totes',        sub: '1,000 L units'    },
                      { value: 'barrels',      label: 'Barrels',          sub: '225 L French/Am.' },
                      { value: 'tanker-truck', label: 'Road Tanker',      sub: 'Up to 30,000 L'   },
                    ].map(opt => (
                      <label class="flex flex-col items-center text-center cursor-pointer p-4 border-2 border-zinc-200 rounded-lg hover:border-wine-950 hover:bg-wine-50 transition-colors has-[:checked]:border-wine-950 has-[:checked]:bg-wine-50">
                        <input
                          type="radio"
                          name="packaging-preference"
                          value={opt.value}
                          class="sr-only"
                          required
                        />
                        <span class="text-sm font-semibold text-zinc-800">{opt.label}</span>
                        <span class="text-xs text-zinc-400 mt-0.5">{opt.sub}</span>
                      </label>
                    ))}
                  </div>
                  <p class="mt-1.5 text-xs text-zinc-400">Select your primary delivery format. Multiple formats can be discussed in the message field below.</p>
                </div>

                <!-- Technical Requirements / Specification -->
                <div class="sm:col-span-2">
                  <label for="tech-requirements" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Technical Requirements / Special Notes
                  </label>
                  <textarea
                    id="tech-requirements"
                    name="tech-requirements"
                    rows="3"
                    placeholder="e.g. Target alcohol 13.5%, unoaked, vegan certified, low-sulphite, specific pH range…"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors resize-none"
                  ></textarea>
                </div>

              </div>
            </fieldset>

            <!-- ── Section: Message ── -->
            <fieldset>
              <legend class="font-serif text-xl font-bold text-zinc-900 mb-6 pb-3 border-b border-zinc-200 w-full">
                Additional Information
              </legend>

              <div class="space-y-5">

                <!-- How did you hear about us -->
                <div>
                  <label for="referral" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    How did you hear about Formigal Wines?
                  </label>
                  <select
                    id="referral"
                    name="referral"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors bg-white"
                  >
                    <option value="" disabled selected>Select source…</option>
                    <option value="trade-show">Trade Show / Wine Fair</option>
                    <option value="referral">Industry Referral / Word of Mouth</option>
                    <option value="web-search">Web Search</option>
                    <option value="linkedin">LinkedIn</option>
                    <option value="broker">Wine Broker / Agent</option>
                    <option value="existing-client">Existing Client</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <!-- Message -->
                <div>
                  <label for="message" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Message / Additional Context
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    placeholder="Please share any additional details about your sourcing needs, existing supply arrangements, target markets, or questions about our catalog…"
                    class="w-full px-4 py-2.5 border border-zinc-300 rounded-md text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-wine-950 focus:border-wine-950 transition-colors resize-none"
                  ></textarea>
                </div>

                <!-- GDPR / Privacy consent -->
                <div class="flex items-start gap-3 p-4 bg-zinc-50 rounded-lg border border-zinc-200">
                  <input
                    type="checkbox"
                    id="gdpr-consent"
                    name="gdpr-consent"
                    required
                    class="mt-0.5 w-4 h-4 rounded border-zinc-300 text-wine-950 focus:ring-wine-950 flex-shrink-0"
                  />
                  <label for="gdpr-consent" class="text-xs text-zinc-500 leading-relaxed">
                    <span class="font-semibold text-zinc-700">I consent to Formigal Wines, Lda. storing and using my data</span> to process this trade inquiry and respond to my request. Data will not be shared with third parties. This form is for trade inquiries only; submission does not constitute a contract or guarantee of availability. <span class="text-wine-950 font-medium">Required.</span>
                  </label>
                </div>

              </div>
            </fieldset>

            <!-- Submit -->
            <div class="pt-2">
              <button
                type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-4 bg-wine-950 text-white font-semibold text-sm rounded-md hover:bg-wine-800 transition-colors shadow-md focus:outline-none focus:ring-2 focus:ring-wine-950 focus:ring-offset-2"
              >
                Submit Trade Inquiry
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
              <p class="mt-3 text-xs text-zinc-400">
                By submitting this form you agree to our privacy notice. We aim to respond within 1 business day (CET / WEST).
              </p>
            </div>

          </form>
        </div>

        <!-- ─── SIDEBAR (1/3 width) ─── -->
        <div class="space-y-6">

          <!-- Contact Card -->
          <div class="bg-zinc-900 rounded-xl p-6 text-white">
            <h3 class="font-serif text-lg font-bold mb-5">Direct Contact</h3>
            <ul class="space-y-5">
              <li>
                <div class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-1">Commercial Inquiries</div>
                <a href="mailto:trade@formigalwines.com" class="text-white text-sm hover:text-red-300 transition-colors font-medium">
                  trade@formigalwines.com
                </a>
              </li>
              <li>
                <div class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-1">Phone / WhatsApp</div>
                <a href="tel:+351254000000" class="text-white text-sm hover:text-red-300 transition-colors font-medium">
                  +351 254 000 000
                </a>
              </li>
              <li>
                <div class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-1">Address</div>
                <address class="text-zinc-300 text-sm not-italic leading-relaxed">
                  Quinta da Formigal<br />
                  5085-101 Pinhão<br />
                  Douro Valley, Portugal
                </address>
              </li>
              <li>
                <div class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-1">Office Hours</div>
                <p class="text-zinc-300 text-sm">Mon–Fri: 08:30–18:00 WEST</p>
                <p class="text-zinc-500 text-xs mt-0.5">(GMT+0 / GMT+1 in summer)</p>
              </li>
            </ul>
          </div>

          <!-- What to Expect -->
          <div class="bg-zinc-50 rounded-xl p-6 border border-zinc-200">
            <h3 class="font-serif text-base font-bold text-zinc-900 mb-4">What Happens Next</h3>
            <ol class="space-y-4">
              {[
                { step: '1', title: 'Inquiry Received', desc: 'Your RFP is logged in our CRM within minutes of submission.' },
                { step: '2', title: 'Initial Assessment', desc: 'Commercial team reviews volume, varietal, and logistics requirements against current inventory.' },
                { step: '3', title: 'Proposal Sent', desc: 'We send a formal quote with pricing, COA extract, and availability confirmation within 1 business day.' },
                { step: '4', title: 'Sample Dispatch', desc: 'On request, we can ship a 750ml reference sample of any available lot via courier.' },
                { step: '5', title: 'Contract &amp; Dispatch', desc: 'Upon acceptance, contracts are executed and the lot is reserved. Dispatch within 72 hours.' },
              ].map(item => (
                <li class="flex gap-3">
                  <div class="w-6 h-6 bg-wine-950 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-white text-xs font-bold">{item.step}</span>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-zinc-800">{item.title}</div>
                    <div class="text-xs text-zinc-500 leading-relaxed mt-0.5" set:html={item.desc}></div>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <!-- Trade-Only Notice -->
          <div class="bg-wine-50 border border-wine-950/20 rounded-xl p-5">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-wine-950 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="text-sm font-semibold text-wine-950 mb-1">Trade Buyers Only</h4>
                <p class="text-xs text-zinc-600 leading-relaxed">
                  We supply bulk wine exclusively to registered businesses. We do not sell to the general public or in volumes below 5,000 liters. Consumer inquiries will not be responded to.
                </p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</Layout>
