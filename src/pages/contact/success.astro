---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Inquiry Received"
  description="Your bulk wine trade inquiry has been received. Our team will respond within one business day."
>
  <section class="bg-white min-h-[60vh] flex items-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
      <!-- Success Icon -->
      <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-zinc-900 mb-4">
        Inquiry Received
      </h1>
      <p class="text-zinc-500 text-base leading-relaxed mb-8">
        Thank you for your trade inquiry. Our commercial team has received your request and will review your specification against our current inventory. We aim to respond within <strong class="text-zinc-700">one business day (CET/WEST)</strong>.
      </p>
      <p class="text-zinc-400 text-sm mb-10">
        If your inquiry is urgent, please call us directly on
        <a href="tel:+351254000000" class="text-wine-950 font-semibold hover:underline">+351 254 000 000</a>
        or email <a href="mailto:trade@formigalwines.com" class="text-wine-950 font-semibold hover:underline">trade@formigalwines.com</a>.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/catalog"
          class="inline-flex items-center gap-2 px-7 py-3 bg-wine-950 text-white font-semibold text-sm rounded-md hover:bg-wine-800 transition-colors"
        >
          Browse Bulk Catalog
        </a>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-7 py-3 border border-zinc-300 text-zinc-700 font-semibold text-sm rounded-md hover:border-zinc-400 transition-colors"
        >
          Return to Homepage
        </a>
      </div>
    </div>
  </section>
</Layout>
