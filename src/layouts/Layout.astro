---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Formigal Wines — Premium bulk wine supplier for brands, merchants, and distributors. ISO 22000 certified production in Portugal\'s Douro Valley.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://formigalwines.com');
const currentPath  = Astro.url.pathname;

const navLinks = [
  { label: 'Home',         href: '/'        },
  { label: 'Bulk Catalog', href: '/catalog' },
  { label: 'Our Process',  href: '/process' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>{title} | Formigal Wines — Bulk Wine Supplier, Portugal</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={`${title} | Formigal Wines`} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:locale"      content="en_GB" />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={`${title} | Formigal Wines`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
    rel="stylesheet"
  />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body class="bg-white font-sans text-zinc-800 antialiased">

  <!-- ═══════════════════════════════════════
       NAVIGATION
  ════════════════════════════════════════ -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-zinc-200 shadow-sm">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group flex-shrink-0">
          <div class="w-8 h-8 bg-wine-950 rounded flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 7h12L19 15c-.6 1.8-1.8 3-3 3s-2.4-1.2-3-3L10 7z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
              <line x1="16" y1="18" x2="16" y2="26" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <line x1="12" y1="26" x2="20" y2="26" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="leading-tight">
            <span class="font-serif text-lg font-semibold text-zinc-900 group-hover:text-wine-950 transition-colors block leading-none">
              Formigal Wines
            </span>
            <span class="text-xs text-zinc-400 font-medium tracking-wide hidden sm:block">Bulk Wine Supplier · Portugal</span>
          </div>
        </a>

        <!-- Desktop Nav Links -->
        <div class="hidden md:flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`px-4 py-2 text-sm font-medium rounded-md transition-colors ${
                isActive(link.href)
                  ? 'text-wine-950 bg-wine-50 font-semibold'
                  : 'text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a
            href="/contact"
            class="ml-4 px-5 py-2.5 bg-wine-950 text-white text-sm font-semibold rounded-md hover:bg-wine-800 transition-colors shadow-sm"
          >
            Request a Quote
          </a>
        </div>

        <!-- Mobile Hamburger -->
        <button
          id="mobile-menu-toggle"
          class="md:hidden p-2 rounded-md text-zinc-500 hover:text-zinc-900 hover:bg-zinc-100 transition-colors"
          aria-label="Open navigation menu"
          aria-expanded="false"
        >
          <svg id="icon-hamburger" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile Menu Drawer -->
      <div id="mobile-menu" class="hidden md:hidden py-4 border-t border-zinc-100">
        <div class="flex flex-col gap-1 pb-2">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`px-4 py-3 text-sm font-medium rounded-md transition-colors ${
                isActive(link.href)
                  ? 'text-wine-950 bg-wine-50 font-semibold'
                  : 'text-zinc-700 hover:text-zinc-900 hover:bg-zinc-50'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a
            href="/contact"
            class="mt-3 px-4 py-3 bg-wine-950 text-white text-sm font-semibold rounded-md text-center hover:bg-wine-800 transition-colors"
          >
            Request a Quote
          </a>
        </div>
      </div>
    </nav>
  </header>

  <!-- ═══════════════════════════════════════
       PAGE CONTENT
  ════════════════════════════════════════ -->
  <main>
    <slot />
  </main>

  <!-- ═══════════════════════════════════════
       FOOTER
  ════════════════════════════════════════ -->
  <footer class="bg-zinc-900 text-zinc-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

        <!-- Brand -->
        <div class="lg:col-span-2">
          <a href="/" class="flex items-center gap-2.5 mb-5">
            <div class="w-8 h-8 bg-wine-950 rounded flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-white" viewBox="0 0 32 32" fill="none">
                <path d="M10 7h12L19 15c-.6 1.8-1.8 3-3 3s-2.4-1.2-3-3L10 7z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" fill="none"/>
                <line x1="16" y1="18" x2="16" y2="26" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="12" y1="26" x2="20" y2="26" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </div>
            <span class="font-serif text-lg font-semibold text-white">Formigal Wines</span>
          </a>
          <p class="text-sm text-zinc-400 leading-relaxed max-w-xs">
            Premium bulk wine producer based in the Douro Valley, Portugal. We supply technically-certified, contract-ready bulk wine to brands, merchants, and distributors across 35+ markets.
          </p>
          <!-- Certification Badges -->
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-zinc-800 text-zinc-400 text-xs rounded font-mono border border-zinc-700">ISO 22000</span>
            <span class="px-2.5 py-1 bg-zinc-800 text-zinc-400 text-xs rounded font-mono border border-zinc-700">FSSC 22000</span>
            <span class="px-2.5 py-1 bg-zinc-800 text-zinc-400 text-xs rounded font-mono border border-zinc-700">OIV Compliant</span>
            <span class="px-2.5 py-1 bg-zinc-800 text-zinc-400 text-xs rounded font-mono border border-zinc-700">Vegan Options</span>
          </div>
        </div>

        <!-- Navigation -->
        <div>
          <h4 class="text-white font-semibold text-xs uppercase tracking-widest mb-5">Navigation</h4>
          <ul class="space-y-3">
            <li><a href="/"         class="text-sm text-zinc-400 hover:text-white transition-colors">Home</a></li>
            <li><a href="/catalog"  class="text-sm text-zinc-400 hover:text-white transition-colors">Bulk Catalog</a></li>
            <li><a href="/process"  class="text-sm text-zinc-400 hover:text-white transition-colors">Our Process</a></li>
            <li><a href="/contact"  class="text-sm text-zinc-400 hover:text-white transition-colors">Contact &amp; RFP</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <h4 class="text-white font-semibold text-xs uppercase tracking-widest mb-5">Trade Inquiries</h4>
          <ul class="space-y-4">
            <li class="text-sm text-zinc-400 leading-relaxed">
              <span class="block text-zinc-300 font-medium mb-0.5">Address</span>
              Quinta da Formigal<br />
              5085-101 Pinhão<br />
              Douro Valley, Portugal
            </li>
            <li class="text-sm">
              <span class="block text-zinc-300 font-medium mb-0.5">Commercial</span>
              <a href="mailto:trade@formigalwines.com" class="text-zinc-400 hover:text-white transition-colors">
                trade@formigalwines.com
              </a>
            </li>
            <li class="text-sm">
              <span class="block text-zinc-300 font-medium mb-0.5">Phone / WhatsApp</span>
              <a href="tel:+351254000000" class="text-zinc-400 hover:text-white transition-colors">
                +351 254 000 000
              </a>
            </li>
          </ul>
        </div>

      </div>

      <!-- Bottom Bar -->
      <div class="mt-12 pt-8 border-t border-zinc-800 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-zinc-500 text-center sm:text-left">
          &copy; {new Date().getFullYear()} Formigal Wines, Lda. All rights reserved.
          Bulk wine trade only — not for direct consumer sale. Portugal VAT: PT 999 999 999.
        </p>
        <p class="text-xs text-zinc-600 flex-shrink-0">Built with Astro &amp; Tailwind CSS · Deployed on Netlify</p>
      </div>
    </div>
  </footer>

  <!-- Mobile Menu Script -->
  <script>
    const toggle    = document.getElementById('mobile-menu-toggle');
    const menu      = document.getElementById('mobile-menu');
    const iconHam   = document.getElementById('icon-hamburger');
    const iconClose = document.getElementById('icon-close');

    toggle?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', isOpen);
      iconHam?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  </script>

</body>
</html>
